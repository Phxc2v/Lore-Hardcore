<?xml version="1.0" encoding="utf-8"?>
<!-- Lore-Hardcore In-Game Guide. Three columns: races (left), sections (middle),
     scrollable body text (right). ScrollablePanel wiring (ClipRect/InnerPanel/
     VerticalScrollbar) mirrors LoreHardcoreSettingsScreen — required for correct
     event routing / scrolling. -->
<Prefab>
  <Window>
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Brush="Popup.Background">
      <Children>

        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                MaxWidth="1400" MaxHeight="920"
                MarginLeft="40" MarginRight="40" MarginTop="30" MarginBottom="30"
                HorizontalAlignment="Center" VerticalAlignment="Center">
          <Children>

            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                    Sprite="BlankWhiteSquare_9" Color="#1A1411E0" DoNotAcceptEvents="true"/>

            <!-- HEADER -->
            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                    SuggestedHeight="60" VerticalAlignment="Top">
              <Children>
                <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            MarginLeft="24" Text="@Title"
                            Brush.FontSize="32" Brush.FontColor="#E8D9B9FF"
                            DoNotAcceptEvents="true"/>
                <ButtonWidget DoNotPassEventsToChildren="true"
                              WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                              SuggestedWidth="48" SuggestedHeight="48"
                              HorizontalAlignment="Right" VerticalAlignment="Center"
                              MarginRight="20"
                              Command.Click="ExecuteClose"
                              Brush="Popup.Cancel.Button">
                  <Children>
                    <TextWidget DoNotAcceptEvents="true"
                                WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                Brush="Popup.Button.Text" Brush.FontSize="22"
                                Brush.TextHorizontalAlignment="Center" Text="X"/>
                  </Children>
                </ButtonWidget>
              </Children>
            </Widget>

            <!-- LEFT COLUMN: Races -->
            <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                    SuggestedWidth="190"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    MarginLeft="24" MarginTop="80" MarginBottom="70">
              <Children>
                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                           VerticalAlignment="Top"
                           DataSource="{Races}"
                           StackLayout.LayoutMethod="VerticalTopToBottom">
                  <ItemTemplate>
                    <ButtonWidget DoNotPassEventsToChildren="true"
                                  WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                  SuggestedHeight="44"
                                  Command.Click="ExecuteSelect"
                                  Brush="Popup.Done.Button"
                                  IsEnabled="@IsAvailable"
                                  IsSelected="@IsSelected"
                                  MarginBottom="6">
                      <Children>
                        <TextWidget DoNotAcceptEvents="true"
                                    WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                    Brush="Popup.Button.Text" Brush.FontSize="18"
                                    Brush.TextHorizontalAlignment="Center" Text="@Name"/>
                      </Children>
                    </ButtonWidget>
                  </ItemTemplate>
                </ListPanel>
              </Children>
            </Widget>

            <!-- MIDDLE COLUMN: Sections of the selected race -->
            <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                    SuggestedWidth="270"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    MarginLeft="230" MarginTop="80" MarginBottom="70">
              <Children>
                <!-- Plain ListPanel (NOT a ScrollablePanel) — same proven pattern as the
                     race column in the settings screen, which renders in insertion order
                     top-to-bottom. 10 sections fit without scrolling. -->
                <ListPanel Id="SecList"
                           WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                           VerticalAlignment="Top"
                           DataSource="{Sections}"
                           StackLayout.LayoutMethod="VerticalTopToBottom">
                  <ItemTemplate>
                    <ButtonWidget DoNotPassEventsToChildren="true"
                                  WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                  SuggestedHeight="40"
                                  Command.Click="ExecuteSelect"
                                  Brush="Popup.Done.Button"
                                  IsSelected="@IsSelected"
                                  MarginBottom="5">
                      <Children>
                        <TextWidget DoNotAcceptEvents="true"
                                    WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                    Brush="Popup.Button.Text" Brush.FontSize="15"
                                    Brush.TextHorizontalAlignment="Center" Text="@Name"/>
                      </Children>
                    </ButtonWidget>
                  </ItemTemplate>
                </ListPanel>
              </Children>
            </Widget>

            <!-- RIGHT COLUMN: section title + scrollable body text -->
            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    MarginLeft="520" MarginRight="24" MarginTop="80" MarginBottom="70">
              <Children>

                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                            SuggestedHeight="34" VerticalAlignment="Top"
                            Text="@SectionTitle"
                            Brush.FontSize="24" Brush.FontColor="#FFDA70FF"
                            Brush.TextHorizontalAlignment="Left"
                            DoNotAcceptEvents="true"/>

                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                        VerticalAlignment="Top" MarginTop="46">
                  <Children>
                    <ScrollablePanel Id="LHEncBodyScroll"
                                     WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                     AutoHideScrollBars="true"
                                     ClipRect="BodyClipRect" InnerPanel="BodyClipRect\BodyList"
                                     VerticalScrollbar="..\LHEncBodyScrollbar">
                      <Children>
                        <Widget Id="BodyClipRect"
                                WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                ClipContents="true">
                          <Children>
                            <ListPanel Id="BodyList"
                                       WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                       StackLayout.LayoutMethod="VerticalTopToBottom">
                              <Children>
                                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                            MarginRight="18" MarginBottom="20"
                                            Text="@BodyText"
                                            Brush.FontSize="17" Brush.FontColor="#D8CBB0FF"
                                            Brush.TextHorizontalAlignment="Left"/>
                              </Children>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>

                    <ScrollbarWidget Id="LHEncBodyScrollbar"
                                     WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                     SuggestedWidth="10"
                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                     MarginTop="6" MarginBottom="6" MarginRight="-16"
                                     AlignmentAxis="Vertical" Handle="LHEncBodyHandle"
                                     MaxValue="100" MinValue="0">
                      <Children>
                        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="4"
                                HorizontalAlignment="Center"
                                Sprite="BlankWhiteSquare_9" Color="#5a4033FF" AlphaFactor="0.4"/>
                        <ImageWidget Id="LHEncBodyHandle"
                                     WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                                     SuggestedHeight="40" SuggestedWidth="10"
                                     HorizontalAlignment="Center" Brush="FaceGen.Scrollbar.Handle"/>
                      </Children>
                    </ScrollbarWidget>
                  </Children>
                </Widget>

              </Children>
            </Widget>

            <!-- FOOTER -->
            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                    SuggestedHeight="60" VerticalAlignment="Bottom">
              <Children>
                <ButtonWidget DoNotPassEventsToChildren="true"
                              WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                              SuggestedWidth="180" SuggestedHeight="44"
                              HorizontalAlignment="Right" VerticalAlignment="Center"
                              MarginRight="24"
                              Command.Click="ExecuteClose"
                              Brush="Popup.Cancel.Button">
                  <Children>
                    <TextWidget DoNotAcceptEvents="true"
                                WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                Brush="Popup.Button.Text" Brush.FontSize="18"
                                Brush.TextHorizontalAlignment="Center" Text="@LabelClose"/>
                  </Children>
                </ButtonWidget>
              </Children>
            </Widget>

          </Children>
        </Widget>

      </Children>
    </Widget>
  </Window>
</Prefab>
