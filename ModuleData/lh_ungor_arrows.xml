<?xml version="1.0" encoding="utf-8"?>
<!-- Lore-Hardcore: кастомные стрелы для унгорских разбойников.
     Клиент (QA): полурогому унгору-разбойнику нужен колющий урон стрел = 2.
     Ванильных стрел с колющим=2 нет (default=0, barbed=1, piercing=4), поэтому
     делаем клон barbed_arrows с thrust_damage="2". Свап в экипировку — через
     tor_equipment_sets.xslt (только templates унгор-разбойников). Разбойник (колющий=1)
     получает ванильный barbed_arrows прямым XSLT-свапом, без нового предмета. -->
<Items>
  <Item id="tor_lh_ungor_pierce_arrows"
        name="{=lh_ungor_pierce_arrows}Ungor Barbed Arrows"
        body_name="bo_capsule_arrow"
        holster_body_name="bo_arrow_bl_h_quiver"
        mesh="arrow_bl_g"
        weight="0.05"
        appearance="1"
        flying_mesh="arrow_bl_flying"
        holster_mesh="arrow_bl_h_quiver"
        holster_mesh_with_weapon="arrow_bl_h_quiver"
        Type="Arrows"
        item_holsters="quiver_back_middle:quiver_bolts_2:quiver_bolts"
        holster_position_shift="0.0,0.0,0.15">
    <ItemComponent>
      <Weapon
          weapon_class="Arrow"
          stack_amount="20"
          thrust_speed="0"
          speed_rating="0"
          physics_material="missile"
          missile_speed="10"
          weapon_length="97"
          thrust_damage="2"
          thrust_damage_type="Pierce"
          item_usage="arrow_right"
          passby_sound_code="event:/mission/combat/missile/passby"
          rotation="0, -80, 25"
          sticking_position="0,-0.97,0"
          sticking_rotation="90,0,0"
          center_of_mass="0,0,-0.13"
          modifier_group="arrow">
        <WeaponFlags
            Consumable="true"
            AmmoSticksWhenShot="true"
            AmmoBreaksOnBounceBack="true" />
      </Weapon>
    </ItemComponent>
    <Flags />
  </Item>
</Items>
